{
  "name": "openclaw-panel",
  "version": "1.0.0",
  "description": "OpenClaw 一站式管控台 - 监控、运维、配置管理",
  "main": "server.js",
  "bin": {
    "openclaw-panel": "./bin/start.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop openclaw-panel",
    "pm2:restart": "pm2 restart openclaw-panel",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs openclaw-panel",
    "pm2:setup": "pm2 start ecosystem.config.js && pm2 save && pm2 startup"
  },
  "dependencies": {
    "json5": "^2.2.3"
  },
  "keywords": ["openclaw", "panel", "dashboard", "admin"],
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  }
}
